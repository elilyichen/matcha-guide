  cards: [
    { title: '下一個學習指南', url: '', badge: 'Coming Soon' },
    { title: '第三個主題', url: '', badge: 'Coming Soon' },
  ]
};

function loadData() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    return raw ? { ...DEFAULT, ...JSON.parse(raw) } : { ...DEFAULT };
  } catch { return { ...DEFAULT }; }
}

function saveData(d) {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(d)); } catch(e) { alert('儲存失敗：' + e.message); }
}

/* ─── RENDER ─── */
let data = loadData();

function render() {
  document.getElementById('heroName').textContent    = data.name;
  document.getElementById('heroTagline').innerHTML   = data.tagline.replace(/\n/g,'<br>');
  document.getElementById('featTitle').textContent   = data.featTitle;
  document.getElementById('featDesc').textContent    = data.featDesc;
  document.getElementById('featCategory').textContent= data.featCategory;

  const card = document.getElementById('featuredCard');
  card.href = data.featUrl && data.featUrl !== '#' ? data.featUrl : '#';

  renderCards();
}

function renderCards() {
  const list = document.getElementById('csList');
  list.innerHTML = '';
  data.cards.forEach((c, i) => {
    const isLink = c.url && c.url.trim();
    const el = document.createElement(isLink ? 'a' : 'div');
    el.className = 'cs-card' + (isLink ? ' has-link' : '');
    if (isLink) { el.href = c.url; el.target = '_blank'; }
    el.innerHTML = `
      <div class="cs-dot"></div>
      <div class="cs-title">${c.title || '...'}</div>
      <div class="cs-badge">${c.badge || 'Coming Soon'}</div>
      ${isLink ? '<div class="cs-arrow">→</div>' : ''}
    `;
    el.addEventListener('click', (e) => {
      if (document.body.classList.contains('editing')) {
        e.preventDefault(); e.stopPropagation();
        openPanelEdit(i);
      }
    });
    list.appendChild(el);
  });
}

/* ─── EDIT MODE ─── */
let editing = false;
let snapshot = null;

function toggleEdit() {
  editing ? cancelEdit() : startEdit();
}

function startEdit() {
  editing = true;
  snapshot = JSON.stringify(data);
  document.body.classList.add('editing');
  document.getElementById('editBanner').classList.add('show');
  document.getElementById('editToggle').classList.add('active');
  document.getElementById('editToggle').textContent = '✕';

  // make hero fields editable
  makeEditable('heroName', v => data.name = v);
  makeEditable('heroTagline', v => data.tagline = v.replace(/<br\s*\/?>/gi,'\n').replace(/&nbsp;/g,' '));
  makeEditable('featTitle', v => data.featTitle = v);
  makeEditable('featDesc', v => data.featDesc = v);
  makeEditable('featCategory', v => data.featCategory = v);

  // featured URL prompt on click of arrow area
  document.getElementById('featuredCard').addEventListener('click', handleFeatClick);
}

function makeEditable(id, setter) {
  const el = document.getElementById(id);
  el.contentEditable = 'true';
  el.addEventListener('input', () => setter(el.innerHTML));
}

function handleFeatClick(e) {
  if (!editing) return;
  e.preventDefault();
  const url = prompt('抹茶指南的網址：', data.featUrl === '#' ? '' : data.featUrl);
  if (url !== null) { data.featUrl = url.trim() || '#'; }
}

function saveEdit() {
  // collect current contenteditable values
  data.name        = document.getElementById('heroName').textContent.trim();
  data.tagline     = document.getElementById('heroTagline').innerText.trim();
  data.featTitle   = document.getElementById('featTitle').textContent.trim();
  data.featDesc    = document.getElementById('featDesc').textContent.trim();
  data.featCategory= document.getElementById('featCategory').textContent.trim();

  saveData(data);
  exitEdit();
  render();

  // brief "saved" flash
  const b = document.getElementById('editBanner');
  b.style.background = '#27ae60';
  setTimeout(() => { b.style.background = ''; }, 900);
}

function cancelEdit() {
  if (snapshot) data = JSON.parse(snapshot);
  exitEdit();
  render();
}

function exitEdit() {
  editing = false;
  document.body.classList.remove('editing');
  document.getElementById('editBanner').classList.remove('show');
  document.getElementById('editToggle').classList.remove('active');
  document.getElementById('editToggle').textContent = '✎';

  ['heroName','heroTagline','featTitle','featDesc','featCategory'].forEach(id => {
    const el = document.getElementById(id);
    el.contentEditable = 'false';
    el.removeEventListener('input', () => {});
  });
  document.getElementById('featuredCard').removeEventListener('click', handleFeatClick);
}

/* ─── CARD PANEL EDIT ─── */
let editingCardIdx = null;

function openPanelEdit(idx) {
  editingCardIdx = idx;
  const c = idx === -1 ? { title:'', url:'', badge:'Coming Soon' } : data.cards[idx];
  document.getElementById('epTitle').value  = c.title  || '';
  document.getElementById('epUrl').value    = c.url    || '';
  document.getElementById('epBadge').value  = c.badge  || 'Coming Soon';
  document.getElementById('epDeleteBtn').style.display = idx === -1 ? 'none' : 'block';
  document.getElementById('editPanelBackdrop').classList.add('open');
}

function closePanelEdit() {
  document.getElementById('editPanelBackdrop').classList.remove('open');
  editingCardIdx = null;
}

function confirmCardEdit() {
  const c = {
    title: document.getElementById('epTitle').value.trim() || '新作品',
    url:   document.getElementById('epUrl').value.trim(),
    badge: document.getElementById('epBadge').value.trim() || 'Coming Soon',
  };
  if (editingCardIdx === -1) {
    data.cards.push(c);
  } else if (editingCardIdx !== null) {
    data.cards[editingCardIdx] = c;
  }
  closePanelEdit();
  renderCards();
}

function deleteCard() {
  if (editingCardIdx !== null && editingCardIdx >= 0) {
    data.cards.splice(editingCardIdx, 1);
  }
  closePanelEdit();
  renderCards();
}

function addCard() { openPanelEdit(-1); }

// close panel on backdrop click
document.getElementById('editPanelBackdrop').addEventListener('click', function(e) {
  if (e.target === this) closePanelEdit();
});

// ESC to exit edit
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') { if (document.getElementById('editPanelBackdrop').classList.contains('open')) closePanelEdit(); else if (editing) cancelEdit(); }
});

// init
render();
</script>
</body>
</html>
