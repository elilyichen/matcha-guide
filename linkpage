<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>@lyichen1 · 林怡辰</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&family=Noto+Serif+TC:wght@300;400;700&display=swap" rel="stylesheet">
<style>
:root {
  --ink:    #12100e;
  --paper:  #f4efe8;
  --gold:   #b8976a;
  --gold-l: #d4b896;
  --warm:   #e8e0d4;
  --muted:  #8a7e72;
  --accent: #2c4a38;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  background:var(--paper);color:var(--ink);
  font-family:'DM Sans',sans-serif;
  min-height:100vh;overflow-x:hidden;
}
body::before{
  content:'';position:fixed;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  background-size:180px;pointer-events:none;z-index:0;opacity:0.6;
}
.wrap{max-width:480px;margin:0 auto;padding:0 24px 80px;position:relative;z-index:1;}

/* ── EDIT MODE BANNER ── */
.edit-banner{
  position:fixed;top:0;left:0;right:0;z-index:999;
  background:var(--accent);color:#e8f0e0;
  display:flex;align-items:center;justify-content:space-between;
  padding:10px 20px;
  font-size:12px;letter-spacing:1px;
  transform:translateY(-100%);
  transition:transform 0.3s ease;
}
.edit-banner.show{transform:translateY(0);}
.edit-banner-left{display:flex;align-items:center;gap:8px;font-family:'DM Sans',sans-serif;}
.edit-dot{width:7px;height:7px;border-radius:50%;background:#7ab648;animation:pulse 1.5s infinite;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:0.4;}}
.edit-btns{display:flex;gap:8px;}
.edit-btn{
  padding:5px 14px;border:none;cursor:pointer;
  font-family:'DM Sans',sans-serif;font-size:11px;letter-spacing:1px;
  border-radius:2px;transition:all 0.2s;
}
.btn-save{background:#7ab648;color:#fff;}
.btn-save:hover{background:#5a9632;}
.btn-cancel{background:rgba(255,255,255,0.15);color:#e8f0e0;}
.btn-cancel:hover{background:rgba(255,255,255,0.25);}

/* ── EDIT TOGGLE (bottom right float) ── */
.edit-toggle{
  position:fixed;bottom:28px;right:28px;z-index:998;
  width:48px;height:48px;border-radius:50%;
  background:var(--accent);color:#e8f0e0;
  border:none;cursor:pointer;font-size:18px;
  box-shadow:0 4px 20px rgba(44,74,56,0.3);
  transition:all 0.25s;
  display:flex;align-items:center;justify-content:center;
}
.edit-toggle:hover{transform:scale(1.08);box-shadow:0 6px 28px rgba(44,74,56,0.4);}
.edit-toggle.active{background:#c0392b;}

/* ── HERO ── */
.hero{padding-top:72px;padding-bottom:52px;text-align:center;position:relative;}
.hero-lines{position:absolute;top:80px;left:50%;transform:translateX(-50%);width:260px;height:260px;pointer-events:none;}
.hero-lines circle{fill:none;stroke:var(--gold);}
.avatar-wrap{position:relative;width:96px;height:96px;margin:0 auto 22px;}
.avatar-ring{
  position:absolute;inset:-6px;border-radius:50%;
  border:1px solid var(--gold);opacity:0.7;
  animation:rotateSlow 18s linear infinite;
}
.avatar-ring-2{
  position:absolute;inset:-12px;border-radius:50%;
  border:1px solid var(--gold-l);opacity:0.35;
  animation:rotateSlow 28s linear infinite reverse;
}
@keyframes rotateSlow{to{transform:rotate(360deg);}}
.avatar{
  width:96px;height:96px;border-radius:50%;
  background:linear-gradient(135deg,var(--accent) 0%,#4a7a5e 100%);
  display:flex;align-items:center;justify-content:center;
  font-family:'Cormorant Garamond',serif;
  font-size:36px;color:#e8f0e0;font-weight:300;
  position:relative;z-index:2;
}
.hero-handle{font-size:11px;letter-spacing:3px;color:var(--muted);text-transform:uppercase;margin-bottom:8px;}
.hero-name{
  font-family:'Cormorant Garamond',serif;
  font-size:38px;font-weight:300;color:var(--ink);
  letter-spacing:-0.5px;margin-bottom:10px;font-style:italic;
}
.hero-tagline{font-size:13px;line-height:1.85;color:var(--muted);max-width:280px;margin:0 auto 26px;}
.hero-divider{width:40px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin:0 auto;}

/* ── Section label ── */
.section-lbl{
  font-size:9px;letter-spacing:5px;color:var(--gold);
  text-transform:uppercase;
  margin:44px 0 16px;
  display:flex;align-items:center;gap:12px;
}
.section-lbl::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,var(--gold-l),transparent);opacity:0.4;}

/* ── FEATURED CARD ── */
.featured-card{
  display:block;text-decoration:none;color:inherit;
  border:1px solid rgba(184,151,106,0.25);
  background:#fff;overflow:hidden;position:relative;
  transition:transform 0.28s cubic-bezier(0.34,1.56,0.64,1),box-shadow 0.28s,border-color 0.2s;
}
.featured-card:hover{
  transform:translateY(-4px);
  box-shadow:0 16px 48px rgba(44,74,56,0.12);
  border-color:rgba(184,151,106,0.55);
}
.featured-thumb{width:100%;height:180px;overflow:hidden;position:relative;}
.featured-thumb svg{width:100%;height:100%;display:block;}
.featured-thumb-overlay{
  position:absolute;inset:0;
  background:linear-gradient(to bottom,rgba(12,30,16,0.08) 0%,rgba(12,30,16,0.52) 100%);
}
.featured-badge{
  position:absolute;top:14px;left:14px;
  font-size:8px;letter-spacing:3px;color:#e8f0e0;
  background:rgba(44,74,56,0.85);padding:4px 10px;text-transform:uppercase;
}
.featured-body{padding:22px 24px 20px;}
.featured-category{font-size:9px;letter-spacing:4px;color:var(--gold);text-transform:uppercase;margin-bottom:8px;}
.featured-title{font-family:'Cormorant Garamond',serif;font-size:26px;color:var(--ink);line-height:1.2;margin-bottom:8px;}
.featured-desc{font-size:12px;line-height:1.8;color:var(--muted);margin-bottom:18px;}
.featured-meta{display:flex;gap:10px;align-items:center;}
.feat-chip{font-size:9px;letter-spacing:2px;color:var(--accent);background:#eef4f0;padding:4px 10px;text-transform:uppercase;}
.featured-arrow{margin-left:auto;font-size:18px;color:var(--gold);transition:transform 0.2s;}
.featured-card:hover .featured-arrow{transform:translateX(4px);}

/* ── COMING SOON cards ── */
.cs-list{display:flex;flex-direction:column;gap:2px;}
.cs-card{
  display:flex;align-items:center;gap:16px;
  padding:17px 20px;
  border:1px dashed rgba(184,151,106,0.32);
  background:rgba(244,239,232,0.55);
  transition:border-color 0.2s,background 0.2s;
  position:relative;
}
.cs-card.has-link{
  border-style:solid;
  border-color:rgba(184,151,106,0.28);
  background:#fff;
  cursor:pointer;text-decoration:none;color:inherit;display:flex;
}
.cs-card.has-link:hover{
  border-color:rgba(184,151,106,0.55);
  transform:translateX(4px);
  box-shadow:0 6px 24px rgba(44,74,56,0.08);
}
.cs-dot{
  width:8px;height:8px;border-radius:50%;
  background:var(--gold-l);flex-shrink:0;
}
.cs-card.has-link .cs-dot{background:var(--accent);}
.cs-title{
  font-family:'Cormorant Garamond',serif;
  font-size:17px;color:var(--ink);flex:1;
}
.cs-card:not(.has-link) .cs-title{color:var(--muted);font-style:italic;}
.cs-badge{
  font-size:8px;letter-spacing:2px;color:var(--muted);
  border:1px solid var(--gold-l);padding:3px 8px;
  text-transform:uppercase;white-space:nowrap;flex-shrink:0;
}
.cs-card.has-link .cs-badge{color:var(--accent);border-color:rgba(44,74,56,0.3);}
.cs-arrow{font-size:15px;color:var(--gold-l);flex-shrink:0;transition:transform 0.2s,color 0.2s;}
.cs-card.has-link:hover .cs-arrow{transform:translateX(3px);color:var(--gold);}

/* ── FOOTER ── */
.footer{text-align:center;margin-top:48px;font-size:10px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;opacity:0.55;}

/* ── Entry animations ── */
@keyframes fadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
.hero{animation:fadeUp 0.9s 0.1s both;}
.section-lbl:nth-of-type(1){animation:fadeUp 0.7s 0.3s both;}
.featured-card{animation:fadeUp 0.8s 0.42s both;}
.section-lbl:nth-of-type(2){animation:fadeUp 0.7s 0.54s both;}
.cs-list{animation:fadeUp 0.7s 0.64s both;}
.footer{animation:fadeUp 0.6s 0.78s both;}

/* ── EDIT MODE styles ── */
body.editing .hero-name[contenteditable],
body.editing .hero-tagline[contenteditable],
body.editing .featured-title[contenteditable],
body.editing .featured-desc[contenteditable],
body.editing .featured-category[contenteditable],
body.editing .cs-title[contenteditable]{
  outline:none;
  border-bottom:1.5px dashed var(--gold);
  padding-bottom:2px;
  cursor:text;
  background:rgba(184,151,106,0.06);
  border-radius:2px;
}
body.editing .featured-card{pointer-events:none;}
body.editing .featured-card [contenteditable]{pointer-events:auto;}

/* ── EDIT PANEL (modal for cs cards) ── */
.edit-panel-backdrop{
  display:none;
  position:fixed;inset:0;background:rgba(18,16,14,0.55);
  z-index:1000;align-items:center;justify-content:center;
  backdrop-filter:blur(4px);
}
.edit-panel-backdrop.open{display:flex;}
.edit-panel{
  background:var(--paper);
  width:min(420px,92vw);
  border-radius:3px;
  padding:32px;
  animation:fadeUp 0.3s both;
}
.ep-title{font-family:'Cormorant Garamond',serif;font-size:22px;color:var(--ink);margin-bottom:20px;}
.ep-field{margin-bottom:16px;}
.ep-label{font-size:10px;letter-spacing:3px;color:var(--muted);text-transform:uppercase;margin-bottom:6px;display:block;}
.ep-input{
  width:100%;padding:10px 12px;
  border:1px solid rgba(184,151,106,0.35);background:#fff;
  font-family:'DM Sans',sans-serif;font-size:13px;color:var(--ink);
  outline:none;border-radius:2px;
  transition:border-color 0.2s;
}
.ep-input:focus{border-color:var(--gold);}
.ep-btns{display:flex;gap:10px;margin-top:22px;justify-content:flex-end;}
.ep-btn{
  padding:8px 20px;border:none;cursor:pointer;
  font-family:'DM Sans',sans-serif;font-size:11px;letter-spacing:1px;
  border-radius:2px;transition:all 0.2s;
}
.ep-confirm{background:var(--accent);color:#e8f0e0;}
.ep-confirm:hover{background:#1e3428;}
.ep-delete{background:#c0392b;color:#fff;}
.ep-delete:hover{background:#a93226;}
.ep-close{background:var(--warm);color:var(--muted);}
.ep-close:hover{background:var(--gold-l);color:#fff;}

/* ── ADD CARD button ── */
.add-cs-btn{
  display:none;
  width:100%;padding:14px;
  border:1px dashed rgba(184,151,106,0.38);
  background:transparent;cursor:pointer;
  font-family:'DM Sans',sans-serif;font-size:11px;letter-spacing:2px;
  color:var(--muted);text-transform:uppercase;
  margin-top:2px;
  transition:all 0.2s;border-radius:2px;
}
.add-cs-btn:hover{border-color:var(--gold);color:var(--gold);background:rgba(184,151,106,0.05);}
body.editing .add-cs-btn{display:block;}
body.editing .cs-card{cursor:pointer;}
body.editing .cs-card::after{
  content:'✎ 編輯';
  position:absolute;right:14px;top:50%;transform:translateY(-50%);
  font-size:9px;letter-spacing:2px;color:var(--gold);opacity:0;
  transition:opacity 0.2s;text-transform:uppercase;
}
body.editing .cs-card:hover::after{opacity:1;}
</style>
</head>
